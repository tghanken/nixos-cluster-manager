#!/usr/bin/env bash
# Used by https://direnv.net

# Automatically reload when this file changes
watch_file nix/devshell.nix
watch_file nix/devshells/*.toml
watch_file nix/devshells/*.nix

source_url \
  https://omnix.page/om/develop/omnixrc/v1 \
  'sha256-FBAVRYkaexKeFKQGUxaPHqhBnqA7km7++O77dKiyD0I='
watch_file om.yaml
use omnix

# Extend the environment with per-user overrides
source_env_if_exists .envrc.local
dotenv
